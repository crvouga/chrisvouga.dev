{
  "type": "module",
  "scripts": {
    "start": "bun --watch ./src/main.ts & bunx serve dist",
    "dev": "bun run start",
    "local": "bun run start",
    "build": "bun run ./src/main.ts",
    "test": "bun test",
    "typecheck": "tsc",
    "optimize-images": "bun run ./src/optimize-images.ts",
    "screenshot-work": "bun run ./src/screenshot-work-websites.ts",
    "screenshot-projects": "bun run ./src/screenshot-project-websites.ts",
    "screenshot-main": "bun run ./src/screenshot-main-site.ts",
    "generate-all": "bun run screenshot-work && bun run screenshot-projects && bun run optimize-images && bun run generate-resume && bun run screenshot-main",
    "generate-resume": "bun run ./src/generate-resume.ts",
    "preview": "docker build -t portfolio-app . && docker run -p 80:80 portfolio-app",
    "clone-projects": "bun run scripts/clone-projects.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "playwright": "^1.48.0",
    "typescript": "^5.9.3"
  }
}